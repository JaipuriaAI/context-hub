{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "claude-context-hub",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-14",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "context-hub-db",
			"database_id": "YOUR_D1_DATABASE_ID"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "CONTEXT_HUB",
				"class_name": "ContextHub"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"ContextHub"
			]
		}
	]
}